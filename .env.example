# ── Game server ───────────────────────────────────────────────────────────────
# Display name shown in the launcher and on the master server list.
SERVER_NAME=Frostfall Roleplay

# UDP port the game server listens on.
SERVER_PORT=7777

# Maximum simultaneous player connections.
MAX_PLAYERS=100

# Set to "true" to run without master-server authentication (LAN / dev use).
OFFLINE_MODE=false

# ── Skyrim data ───────────────────────────────────────────────────────────────
# Absolute path to the Skyrim Special Edition Data/ directory.
# The five vanilla .esm files (Skyrim, Update, Dawnguard, HearthFires, Dragonborn)
# are appended to the loadOrder array automatically.
SKYRIM_DATA_PATH=C:/Program Files (x86)/Steam/steamapps/common/Skyrim Special Edition/Data

# ── NPC ───────────────────────────────────────────────────────────────────────
NPC_ENABLED=false

# ── Discord OAuth — used by Frostfall-Backend for launcher login ──────────────
# Create an application at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ── Discord Bot — used by the game server for role/ban enforcement ────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_BAN_ROLE_ID=
DISCORD_EVENT_LOG_CHANNEL_ID=
DISCORD_HIDE_IP_ROLE_ID=

# ── Metrics HTTP auth — protects the /metrics endpoint on port 3000 ──────────
# Leave both empty to disable auth (endpoint accessible without credentials).
METRICS_USER=
METRICS_PASSWORD=

# ── Master server ─────────────────────────────────────────────────────────────
# URL of the SkyMP master gateway. Leave empty for private / offline use.
MASTER_URL=
